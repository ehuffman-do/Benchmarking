{# Shared CSS for run and compare reports. Inlined into a <style> tag. #}
:root { color-scheme: light; }
* { box-sizing: border-box; }
body {
  background: #ffffff; color: #1a1f26;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 15px; line-height: 1.55;
  max-width: 1280px; margin: 0 auto; padding: 48px 56px 96px;
}
h1 { font-size: 30px; margin: 0 0 6px; }
h2 { font-size: 22px; margin: 56px 0 16px; border-bottom: 2px solid #e3e8ee; padding-bottom: 8px; }
h3 { font-size: 17px; margin: 28px 0 10px; }
.subtle { color: #5b6573; }
.card {
  border: 1px solid #dde3ea; border-radius: 10px; padding: 24px 28px; margin: 24px 0;
  background: #fafbfc;
}
.meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 8px 32px; }
.meta-grid div { padding: 3px 0; }
.meta-grid b { color: #36404c; }
.badge { display: inline-block; padding: 2px 12px; border-radius: 999px; font-weight: 600; font-size: 14px; }
.badge.complete { background: #e2f4e6; color: #176b2c; }
.badge.partial  { background: #fdf0d4; color: #8a5a00; }
.badge.failed   { background: #fde0de; color: #a01b12; }
table { border-collapse: collapse; width: 100%; margin: 16px 0; font-size: 14px; }
th, td { border: 1px solid #dde3ea; padding: 8px 12px; text-align: right; }
th { background: #f1f4f8; color: #36404c; font-size: 13.5px; }
th:first-child, td:first-child { text-align: left; }
td.warn { background: #fdf0d4; font-weight: 600; }
td.fail, tr.fail td { background: #fde0de; }
.chart { margin: 28px 0; }
.chart img { width: 100%; height: auto; border: 1px solid #e9edf2; border-radius: 8px; }
pre {
  background: #f5f7fa; border: 1px solid #dde3ea; border-radius: 8px;
  padding: 14px 16px; overflow-x: auto; font-size: 13px;
}
details { margin: 16px 0; }
details summary { cursor: pointer; font-weight: 600; padding: 8px 0; }
footer { margin-top: 64px; color: #8b95a3; font-size: 13px; border-top: 1px solid #e3e8ee; padding-top: 16px; }
.note { background: #eef4fb; border-left: 4px solid #4d82bc; padding: 10px 16px; border-radius: 0 8px 8px 0; margin: 14px 0; }
